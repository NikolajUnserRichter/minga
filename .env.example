# Minga-Greens ERP - Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an

# Domain (for production HTTPS via Caddy)
# DOMAIN=erp.minga-greens.de

# PostgreSQL Datenbank
POSTGRES_USER=minga
POSTGRES_PASSWORD=minga_secret_change_me
POSTGRES_DB=minga_erp

# Backend
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_change_me

# E-Mail (SMTP) — benötigt für Mahnungen & Benachrichtigungen
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@minga-greens.de
SMTP_PASSWORD=email_password
EMAILS_FROM_NAME=Minga Greens
EMAILS_FROM_EMAIL=info@minga-greens.de

# Mahnwesen / Dunning (Tage nach Fälligkeit)
# DUNNING_LEVEL1_DAYS=3
# DUNNING_LEVEL2_DAYS=14
# DUNNING_LEVEL3_DAYS=28
# DUNNING_FEE_LEVEL2=5.00
# DUNNING_FEE_LEVEL3=10.00

# Qualitätskontrolle
# QUALITY_MIN_NOTE=2
# QUALITY_MAX_LOSS_PERCENT=20.0
